---
import { sanityClient } from "sanity:client";
import { PortableText } from "astro-portabletext";
import Layout from "../../layouts/Layout.astro";

export async function getStaticPaths() {
  const posts = await sanityClient.fetch(`*[_type == "post" && defined(slug.current)]{
    "params": {"slug": slug.current}
  }`);
  
  return posts;
}

const { slug } = Astro.params;

const query = `*[_type == "post" && slug.current == $slug][0]{
  _id,
  title,
  metaTitle,
  metaDescription,
  canonicalUrl,
  publishedAt,
  body,
  "imageUrl": mainImage.asset->url,
  "ogImageUrl": ogImage.asset->url,
  "authorName": author->name,
  "authorRole": author->role,
  "authorSlug": author->slug.current,
  "authorSocial": author->socialLinks,
  "categories": categories[]->{ title, "slug": slug.current },
  "tags": tags[]->{ title, "slug": slug.current }
}`;

const post = await sanityClient.fetch(query, { slug });

if (!post) {
  return new Response("Post not found", { status: 404 });
}

// Fetch related posts based on matching tags or categories
const currentCategorySlugs = post.categories?.map((c: any) => c.slug) || [];
const currentTagSlugs = post.tags?.map((t: any) => t.slug) || [];

const relatedPostsQuery = `*[_type == "post" && _id != $currentId && (count((categories[]->slug.current)[@ in $catSlugs]) > 0 || count((tags[]->slug.current)[@ in $tagSlugs]) > 0)] | order(publishedAt desc)[0...2] {
  _id,
  title,
  "slug": slug.current,
  excerpt,
  publishedAt,
  "imageUrl": mainImage.asset->url
}`;

const relatedPosts = await sanityClient.fetch(relatedPostsQuery, {
  currentId: post._id,
  catSlugs: currentCategorySlugs,
  tagSlugs: currentTagSlugs
});

// Prepare JSON-LD for E-E-A-T
const schemaUrl = Astro.url.href;
const authorUrl = post.authorSlug ? `https://www.drnathanmarketing.com/authors/${post.authorSlug}#person` : "https://www.drnathanmarketing.com/#organization";

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": post.metaTitle || post.title,
  "image": [
    post.ogImageUrl || post.imageUrl || "https://www.drnathanmarketing.com/assets/logo/logo.png"
   ],
  "datePublished": post.publishedAt || new Date().toISOString(),
  "author": [{
      "@type": post.authorName ? "Person" : "Organization",
      "@id": authorUrl,
      "name": post.authorName || "Dr. Nathan Marketing",
      "jobTitle": post.authorRole || undefined,
      "sameAs": post.authorSocial?.map((link: any) => link.url) || []
  }]
};
---

<Layout 
  title={post.metaTitle || post.title} 
  description={post.metaDescription || "Read our latest medical marketing insights."}
  image={post.ogImageUrl || post.imageUrl}
  canonical={post.canonicalUrl}
>
  <script slot="head" type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

  <div class="relative bg-[#fafafa] min-h-screen pb-24">
    
    <!-- Article Hero Banner -->
    <div class="relative w-full h-[55vh] md:h-[65vh] lg:h-[70vh] bg-slate-900 flex items-end justify-center overflow-hidden">
      <!-- Background Image -->
      {post.imageUrl ? (
        <img 
          src={post.imageUrl} 
          alt={post.title} 
          class="absolute inset-0 w-full h-full object-cover opacity-50 mix-blend-overlay scale-105"
        />
      ) : (
        <div class="absolute inset-0 w-full h-full bg-gradient-to-tr from-primary-950 to-slate-800 opacity-80"></div>
      )}
      
      <!-- Gradient overlay for text readability -->
      <div class="absolute inset-0 bg-gradient-to-t from-slate-950 via-slate-900/60 to-slate-900/10"></div>

      <!-- Hero Content -->
      <div class="relative z-10 w-full max-w-screen-md mx-auto px-4 lg:px-0 pb-16 md:pb-24 text-center" data-article-reveal>
        <div class="flex items-center justify-center gap-2 mb-8">
          <a href="/blog" class="text-xs font-bold tracking-[0.2em] text-primary-300 uppercase hover:text-white transition-colors">
            &larr; Back to Editorial
          </a>
        </div>
        <h1 class="font-helvetica text-3xl md:text-4xl lg:text-5xl font-bold text-white mb-8 max-w-[850px] mx-auto py-2" style="line-height: 1.8;">
          {post.title}
        </h1>
        
        <div class="flex items-center justify-center gap-4 md:gap-6 text-slate-300 text-sm md:text-base font-medium">
          {post.authorName && (
            <div class="flex items-center gap-2">
              <span class="w-1.5 h-1.5 rounded-full bg-primary-400"></span>
              <span>{post.authorName} {post.authorRole ? `— ${post.authorRole}` : ''}</span>
            </div>
          )}
          {post.publishedAt && (
             <div class="flex items-center gap-2 border-l border-slate-600 pl-4 md:pl-6">
              <span>{new Date(post.publishedAt).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}</span>
            </div>
          )}
        </div>
      </div>
    </div>

    <!-- Article Body -->
    <main class="relative z-20 -mt-12 mx-auto px-4 max-w-screen-md w-full">
       <div class="bg-white rounded-[2rem] shadow-[0_20px_40px_-15px_rgba(0,0,0,0.05)] p-6 sm:p-10 md:p-16 border border-slate-100" data-article-reveal>
        <article class="prose prose-slate prose-lg max-w-none md:prose-xl mx-auto prose-headings:font-helvetica prose-headings:font-bold prose-headings:tracking-tight prose-a:text-primary-600 prose-a:no-underline hover:prose-a:text-primary-500 hover:prose-a:underline prose-img:rounded-3xl prose-img:shadow-lg">
          <PortableText value={post.body} />
        </article>

        {/* Display tags and categories here at the bottom of the article card */}
        {(post.categories?.length > 0 || post.tags?.length > 0) && (
          <div class="mt-12 pt-8 border-t border-slate-100 flex flex-wrap gap-3 items-center">
             <span class="text-xs font-bold text-slate-400 uppercase tracking-widest mr-2">Filed Under</span>
             {post.categories?.map((cat: any) => (
                <span class="px-3 py-1 bg-primary-50 text-primary-700 text-xs font-semibold rounded-full border border-primary-100">{cat.title}</span>
             ))}
             {post.tags?.map((tag: any) => (
                <span class="px-3 py-1 bg-slate-50 text-slate-600 text-xs font-semibold rounded-full border border-slate-200">#{tag.title}</span>
             ))}
          </div>
        )}
      </div>

      <!-- Footer CTA for article -->
       <div class="mt-20 text-center" data-article-reveal>
        <p class="text-xs font-bold tracking-[0.2em] text-slate-400 uppercase mb-6">Share This Insight</p>
        <div class="flex gap-4 justify-center">
            <button class="w-14 h-14 rounded-full border border-slate-200 flex items-center justify-center text-slate-600 hover:text-white hover:bg-[#0A66C2] hover:border-[#0A66C2] transition-colors shadow-sm" onclick="window.open(`https://www.linkedin.com/sharing/share-offsite/?url=${window.location.href}`, '_blank')">
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
            </button>
            <button class="w-14 h-14 rounded-full border border-slate-200 flex items-center justify-center text-slate-600 hover:text-white hover:bg-slate-900 hover:border-slate-900 transition-colors shadow-sm" onclick="window.open(`https://twitter.com/intent/tweet?url=${window.location.href}`, '_blank')">
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
            </button>
        </div>
       </div>

      <!-- Related Articles Section -->
      {relatedPosts.length > 0 && (
         <div class="mt-24 pt-16 border-t border-slate-200" data-article-reveal>
           <h3 class="font-helvetica text-2xl md:text-3xl font-bold text-slate-900 mb-10 text-center">Related Reading</h3>
           <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
             {relatedPosts.map((rPost: any) => (
               <a href={`/blog/${rPost.slug}`} class="group flex flex-col no-underline relative bg-transparent">
                 <div class="w-full aspect-[4/3] rounded-3xl overflow-hidden bg-slate-100 mb-6 relative shadow-sm border border-slate-200/60 transition-all duration-500 ease-out group-hover:shadow-[0_20px_40px_-15px_rgba(0,104,180,0.15)] group-hover:-translate-y-2">
                  <div class="absolute inset-0 bg-gradient-to-t from-slate-900/40 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300 z-10"></div>
                  {rPost.imageUrl ? (
                    <img 
                      src={rPost.imageUrl} 
                      alt={rPost.title} 
                      class="w-full h-full object-cover transition-transform duration-700 ease-out group-hover:scale-105 will-change-transform"
                    />
                  ) : (
                    <div class="w-full h-full flex items-center justify-center bg-slate-50 text-slate-300">
                      <svg class="w-12 h-12" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
                      </svg>
                    </div>
                  )}
                 </div>
                 
                 <div class="flex flex-col flex-1 pl-1">
                   <p class="text-xs font-bold tracking-[0.2em] text-primary-600 uppercase mb-3 flex items-center gap-3">
                     <span class="w-1.5 h-1.5 rounded-full bg-primary-500"></span>
                     {rPost.publishedAt ? new Date(rPost.publishedAt).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' }) : 'Analysis'}
                   </p>
                   <h4 class="font-helvetica text-xl font-bold text-slate-900 leading-[1.2] mb-3 group-hover:text-primary-600 transition-colors duration-300 line-clamp-2">
                     {rPost.title}
                   </h4>
                   <p class="text-slate-600 leading-relaxed line-clamp-2 text-[0.95rem] mb-4 flex-1">
                     {rPost.excerpt}
                   </p>
                 </div>
               </a>
             ))}
           </div>
         </div>
      )}

    </main>
  </div>
</Layout>

<script>
  import { gsap } from "gsap";

  const tl = gsap.timeline();
  tl.fromTo(
    "[data-article-reveal]",
    { opacity: 0, y: 40 },
    { opacity: 1, y: 0, duration: 1, stagger: 0.2, ease: "power3.out" }
  );
</script>
