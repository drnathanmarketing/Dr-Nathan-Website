---
import { sanityClient } from "sanity:client";
import Layout from "../../layouts/Layout.astro";

const postsQuery = `*[_type == "post" && defined(slug.current)] | order(publishedAt desc) {
  _id,
  title,
  "slug": slug.current,
  excerpt,
  "bodyText": pt::text(body),
  publishedAt,
  "imageUrl": mainImage.asset->url,
  "categories": categories[]->{ title, "slug": slug.current },
  "tags": tags[]->{ title, "slug": slug.current }
}`;

const categoriesQuery = `*[_type == "category"] | order(title asc) { title, "slug": slug.current }`;
const tagsQuery = `*[_type == "tag"] | order(title asc) { title, "slug": slug.current }`;

const [posts, categories, tags] = await Promise.all([
  sanityClient.fetch(postsQuery),
  sanityClient.fetch(categoriesQuery),
  sanityClient.fetch(tagsQuery),
]);
---

<Layout 
  title="Editorial | Dr. Nathan Marketing" 
  description="Explore premium insights, industry trends, and strategic foresight tailored for modern medical practices and healthcare innovators."
>
  <div class="relative min-h-[90vh] bg-[#fafafa] flex flex-col justify-start overflow-hidden pt-12 md:pt-24 pb-20">
    <!-- Ambient Glow -->
    <div class="absolute inset-0 overflow-hidden pointer-events-none z-0">
      <div class="absolute top-[0%] left-[20%] w-[50%] h-[40%] rounded-full bg-primary-50/60 blur-[120px]"></div>
    </div>

    <main class="max-w-screen-xl mx-auto px-4 md:px-8 relative z-10 w-full">
      <div class="text-center md:text-left mb-12 flex flex-col gap-4">
        <p class="text-xs md:text-sm font-bold tracking-[0.25em] text-primary-600 uppercase" data-reveal>
          Agency Insights
        </p>
        <h1 class="font-helvetica text-5xl md:text-6xl lg:text-[4.5rem] font-bold tracking-tight text-slate-900 leading-[1.05]" data-reveal>
          The <span class="text-transparent bg-clip-text bg-gradient-to-r from-primary-600 to-primary-400">Editorial</span>
        </h1>
        <p class="text-base md:text-lg text-slate-600 max-w-[600px] leading-relaxed mx-auto md:mx-0 mt-4" data-reveal>
          Explore premium insights, industry trends, and strategic foresight tailored for modern medical practices and healthcare innovators.
        </p>
      </div>

      <!-- Search and Filters Section -->
      <div class="mb-12" data-reveal>
        <div class="relative max-w-xl mb-8">
          <div class="absolute inset-y-0 left-0 pl-4 flex items-center pointer-events-none">
            <svg class="h-5 w-5 text-slate-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
            </svg>
          </div>
          <input 
            type="text" 
            id="blog-search" 
            class="block w-full pl-11 pr-4 py-3.5 bg-white border border-slate-200 rounded-2xl text-slate-900 placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-primary-500/20 focus:border-primary-500 transition-all duration-300 shadow-sm text-sm lg:text-base font-medium"
            placeholder="Search articles, insights, and case studies..."
          />
        </div>

        <div class="flex flex-col gap-5">
          {categories && categories.length > 0 && (
            <div class="flex items-center gap-3 flex-wrap" id="category-filters">
              <span class="text-xs font-bold tracking-widest text-slate-400 uppercase mr-2">Categories</span>
              <button class="filter-btn active px-4 py-1.5 rounded-full text-sm font-bold transition-all duration-300 bg-primary-600 text-white border border-primary-600 shadow-sm" data-filter="all" data-type="category">All</button>
              {categories.map((cat: any) => (
                <button class="filter-btn px-4 py-1.5 rounded-full text-sm font-semibold transition-all duration-300 bg-white text-slate-600 border border-slate-200 hover:border-primary-300 hover:text-primary-600 shadow-sm" data-filter={cat.slug} data-type="category">{cat.title}</button>
              ))}
            </div>
          )}

          {tags && tags.length > 0 && (
            <div class="flex items-center gap-3 flex-wrap" id="tag-filters">
              <span class="text-xs font-bold tracking-widest text-slate-400 uppercase mr-2">Topics</span>
              {tags.map((tag: any) => (
                <button class="filter-btn px-3 py-1 rounded-full text-xs font-semibold transition-all duration-300 bg-white text-slate-500 border border-slate-200 hover:border-slate-400 hover:text-slate-800" data-filter={tag.slug} data-type="tag">#{tag.title}</button>
              ))}
            </div>
          )}
        </div>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 md:gap-12 lg:gap-16" id="blog-grid" data-reveal>
        {posts.map((post: any) => {
          const categorySlugs = post.categories?.map((c: any) => c.slug).join(',') || '';
          const tagSlugs = post.tags?.map((t: any) => t.slug).join(',') || '';
          const plainTextContent = (post.bodyText || '').toLowerCase().replace(/[^a-z0-9\s]/g, ' ');
          
          return (
            <a 
              href={`/blog/${post.slug}`} 
              class="blog-card group flex flex-col no-underline relative bg-transparent"
              data-title={post.title.toLowerCase()}
              data-categories={categorySlugs}
              data-tags={tagSlugs}
              data-content={plainTextContent}
            >
              <div class="w-full aspect-[4/3] rounded-3xl overflow-hidden bg-slate-100 mb-6 relative shadow-sm border border-slate-200/60 transition-all duration-500 ease-out group-hover:shadow-[0_20px_40px_-15px_rgba(0,104,180,0.15)] group-hover:-translate-y-2">
                <div class="absolute inset-0 bg-gradient-to-t from-slate-900/40 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300 z-10"></div>
                {post.imageUrl ? (
                  <img 
                    src={post.imageUrl} 
                    alt={post.title} 
                    class="w-full h-full object-cover transition-transform duration-700 ease-out group-hover:scale-105 will-change-transform"
                  />
                ) : (
                  <div class="w-full h-full flex items-center justify-center bg-slate-50 text-slate-300">
                    <svg class="w-12 h-12" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
                    </svg>
                  </div>
                )}
              </div>
              
              <div class="flex flex-col flex-1 pl-1">
                <p class="text-xs font-bold tracking-[0.2em] text-primary-600 uppercase mb-3 flex items-center gap-3">
                  <span class="w-1.5 h-1.5 rounded-full bg-primary-500"></span>
                  {post.publishedAt ? new Date(post.publishedAt).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' }) : 'Analysis'}
                </p>
                
                <h2 class="font-helvetica text-xl md:text-2xl font-bold text-slate-900 leading-[1.35] mb-4 group-hover:text-primary-600 transition-colors duration-300 line-clamp-3">
                  {post.title}
                </h2>
                
                <p class="text-slate-600 leading-relaxed line-clamp-3 text-[0.95rem] md:text-base mb-6 flex-1">
                  {post.excerpt}
                </p>
                
                <div class="mt-auto flex items-center text-sm font-semibold tracking-wide text-slate-900 group-hover:text-primary-600 transition-colors duration-300">
                  Read Article
                  <svg class="w-4 h-4 ml-2 transition-transform duration-300 ease-out group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3" />
                  </svg>
                </div>
              </div>
            </a>
          );
        })}
      </div>
      
      {posts.length === 0 && (
        <div class="py-20 text-center flex flex-col items-center">
          <div class="w-20 h-20 bg-slate-100 rounded-full flex items-center justify-center mb-6">
            <span class="text-2xl">✍️</span>
          </div>
          <h3 class="font-helvetica text-2xl font-bold text-slate-900 mb-2">No publications yet</h3>
          <p class="text-slate-500">We are currently curating our first premium insights.</p>
        </div>
      )}

      <!-- No Results Message (Hidden by default) -->
      <div id="no-results-message" class="hidden py-20 flex-col items-center justify-center w-full col-span-full">
        <div class="w-16 h-16 bg-slate-100 rounded-full flex items-center justify-center mb-4 text-slate-400">
           <svg class="w-8 h-8" fill="none" viewBox="0 0 24 24" stroke="currentColor">
             <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
           </svg>
        </div>
        <h3 class="font-helvetica text-xl font-bold text-slate-900 mb-2">No articles found</h3>
        <p class="text-slate-500">Try adjusting your search or filters to find what you're looking for.</p>
      </div>

    </main>
  </div>
</Layout>

<script>
  import { gsap } from "gsap";

  document.addEventListener('DOMContentLoaded', () => {
    // Initial GSAP animation
    const tl = gsap.timeline();
    tl.fromTo(
      "[data-reveal]",
      { opacity: 0, y: 30 },
      { opacity: 1, y: 0, duration: 1, stagger: 0.15, ease: "power3.out" }
    );

    // Filtering logic
    const searchInput = document.getElementById('blog-search') as HTMLInputElement;
    const cards = document.querySelectorAll('.blog-card');
    const filterBtns = document.querySelectorAll('.filter-btn');
    const noResultsMsg = document.getElementById('no-results-message');
    const blogGrid = document.getElementById('blog-grid');
    
    let currentCategory = 'all';
    let currentActiveTag: string | null = null; // null means no tag filter

    function filterPosts() {
      const searchTerm = searchInput ? searchInput.value.toLowerCase() : '';
      let visibleCount = 0;

      cards.forEach((card) => {
        const c = card as HTMLElement;
        const title = c.getAttribute('data-title') || '';
        const content = c.getAttribute('data-content') || '';
        const categories = (c.getAttribute('data-categories') || '').split(',');
        const tags = (c.getAttribute('data-tags') || '').split(',');

        const matchesSearch = title.includes(searchTerm) || content.includes(searchTerm);
        const matchesCategory = currentCategory === 'all' || categories.includes(currentCategory);
        const matchesTag = currentActiveTag === null || tags.includes(currentActiveTag);

        if (matchesSearch && matchesCategory && matchesTag) {
          c.style.display = 'flex';
          visibleCount++;
        } else {
          c.style.display = 'none';
        }
      });

      if (noResultsMsg && blogGrid) {
        if (visibleCount === 0 && cards.length > 0) {
          noResultsMsg.style.display = 'flex';
          blogGrid.style.display = 'none';
        } else {
          noResultsMsg.style.display = 'none';
          blogGrid.style.display = 'grid'; // Maintain CSS Grid display
        }
      }
    }

    if (searchInput) {
      searchInput.addEventListener('input', filterPosts);
    }

    filterBtns.forEach(btn => {
      btn.addEventListener('click', (e) => {
        const target = e.currentTarget as HTMLElement;
        const type = target.getAttribute('data-type');
        const filterStr = target.getAttribute('data-filter') || '';

        if (type === 'category') {
          currentCategory = filterStr;
          // Update visual state for category buttons
          document.querySelectorAll('.filter-btn[data-type="category"]').forEach(b => {
             b.classList.remove('bg-primary-600', 'text-white', 'border-primary-600');
             b.classList.add('bg-white', 'text-slate-600', 'border-slate-200');
          });
          target.classList.remove('bg-white', 'text-slate-600', 'border-slate-200');
          target.classList.add('bg-primary-600', 'text-white', 'border-primary-600');
        } else if (type === 'tag') {
          // Toggle tag
          if (currentActiveTag === filterStr) {
            currentActiveTag = null; // untoggle
            target.classList.remove('bg-slate-800', 'text-white', 'border-slate-800');
            target.classList.add('bg-white', 'text-slate-500', 'border-slate-200');
          } else {
            currentActiveTag = filterStr;
            document.querySelectorAll('.filter-btn[data-type="tag"]').forEach(b => {
               b.classList.remove('bg-slate-800', 'text-white', 'border-slate-800');
               b.classList.add('bg-white', 'text-slate-500', 'border-slate-200');
            });
            target.classList.remove('bg-white', 'text-slate-500', 'border-slate-200');
            target.classList.add('bg-slate-800', 'text-white', 'border-slate-800');
          }
        }

        filterPosts();
      });
    });
  });
</script>
