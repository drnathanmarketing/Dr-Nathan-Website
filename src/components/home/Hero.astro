---
import glucos from "../../clients/1.png";
import dugro from "../../clients/2.png";
import avolac from "../../clients/3.png";
import sun from "../../clients/4.png";
import vital from "../../clients/5.png";
import roche from "../../clients/6.png";
import skinland from "../../clients/7.png";
import goneyay from "../../clients/8.png";
import ohoo from "../../clients/9.png";
import rejuve from "../../clients/10.png";
import homedoctor from "../../clients/11.png";
import s from "../../clients/12.png";
import client13 from "../../clients/13.png";
import client14 from "../../clients/14.png";
import client15 from "../../clients/15.png";
import client16 from "../../clients/16.png";
import client17 from "../../clients/17.png";
import client18 from "../../clients/18.png";
import client19 from "../../clients/19.png";
import client20 from "../../clients/20.png";
import client21 from "../../clients/21.png";
import client23 from "../../clients/23.png";
import client24 from "../../clients/24.png";

const logos = [
  { src: glucos.src, alt: "glucos" },
  { src: dugro.src, alt: "dugro" },
  { src: avolac.src, alt: "avolac" },
  { src: sun.src, alt: "sun" },
  { src: vital.src, alt: "vital" },
  { src: roche.src, alt: "roche" },
  { src: skinland.src, alt: "skinland" },
  { src: goneyay.src, alt: "goneyay" },
  { src: ohoo.src, alt: "ohoo" },
  { src: rejuve.src, alt: "rejuve" },
  { src: homedoctor.src, alt: "homedoctor" },
  { src: s.src, alt: "s" },
  { src: client13.src, alt: "client13" },
  { src: client14.src, alt: "client14" },
  { src: client15.src, alt: "client15" },
  { src: client16.src, alt: "client16" },
  { src: client17.src, alt: "client17" },
  { src: client18.src, alt: "client18" },
  { src: client19.src, alt: "client19" },
  { src: client20.src, alt: "client20" },
  { src: client21.src, alt: "client21" },
  { src: client23.src, alt: "client23" },
  { src: client24.src, alt: "client24" },
];
---

<div
  id="hero"
  class="relative min-h-[90vh] flex flex-col justify-center overflow-hidden bg-[#fafafa] sm:mb-8 md:mb-16 pt-24 lg:pt-0"
>
  <!-- Minimal Ambient Glow Background -->
  <div class="absolute inset-0 overflow-hidden pointer-events-none z-0">
    <div class="absolute top-[0%] left-[-10%] w-[60%] h-[60%] rounded-full bg-primary-50/40 blur-[120px]"></div>
  </div>

  <div class="max-w-screen-xl mx-auto px-4 py-8 md:py-20 relative z-10 w-full h-full">
    <div class="flex flex-col lg:flex-row items-center gap-12 lg:gap-8 relative w-full h-full">
      
      <!-- Left Column: Editorial Text -->
      <div class="flex-1 flex flex-col gap-6 lg:gap-8 items-center text-center lg:items-start lg:text-left z-20 w-full">
        <p 
          class="text-xs md:text-sm font-bold tracking-[0.25em] text-primary-600 uppercase"
          data-reveal
        >
          Dr. Nathan Marketing & Consultancy
        </p>
        
        <h1 
          class="font-helvetica text-5xl md:text-7xl lg:text-[5.5rem] font-bold tracking-tight text-slate-900 leading-[1.1] md:leading-[1.05]"
          data-reveal
        >
          Elevate Your <br class="hidden lg:block"/>
          <span class="text-transparent bg-clip-text bg-gradient-to-r from-primary-600 to-primary-400">Brand</span>
        </h1>
        
        <p 
          class="text-base md:text-lg text-slate-600 max-w-[500px] leading-relaxed"
          data-reveal
        >
          We are dedicated, forward-thinking professionals committed to exploring and delivering premium, innovative marketing solutions tailored for the healthcare industry.
        </p>
        
        <div class="pt-4" data-reveal>
          <button
            id="hero_learn_more_btn"
            type="button"
            class="group relative inline-flex items-center justify-center px-8 py-4 font-medium text-white transition-all duration-300 ease-out bg-slate-900 rounded-full hover:bg-slate-800 hover:shadow-xl hover:shadow-slate-900/20 hover:-translate-y-1 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-slate-900 w-max"
          >
            <span class="mr-2 tracking-wide text-sm md:text-base">Discover Our Expertise</span>
            <svg 
              class="w-5 h-5 transition-transform duration-300 ease-out group-hover:translate-x-1" 
              fill="none" viewBox="0 0 24 24" stroke="currentColor"
            >
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3" />
            </svg>
          </button>
        </div>
      </div>

      <!-- Right Column: Intricate Luxury Watch Dial Wheel (Desktop Only) -->
      <div 
        class="hidden lg:flex flex-1 w-full relative flex-col justify-center items-end lg:h-[700px] pointer-events-none mt-4 lg:mt-0 z-10"
        data-reveal-container
      >
        <div class="pointer-events-auto absolute lg:top-12 lg:right-[-250px] lg:w-[900px] lg:h-[900px] rounded-full animate-spin-custom">
          
          <!-- Backing glass plate -->
          <div class="absolute inset-0 bg-gradient-to-br from-white/70 to-white/20 backdrop-blur-3xl rounded-full border border-white/60 shadow-[0_0_80px_rgba(0,0,0,0.03)]"></div>
          
          <!-- Outer fine rings -->
          <div class="absolute lg:inset-[40px] border border-slate-200/40 rounded-full"></div>
          <div class="absolute lg:inset-[44px] border border-slate-100/30 rounded-full"></div>
          
          <!-- Outer Dashed orbit ring -->
          <div class="absolute lg:inset-[100px] border border-dashed border-slate-300/80 rounded-full bg-slate-50/10"></div>
          <div class="absolute lg:inset-[104px] border border-slate-200/30 rounded-full"></div> 
          
          <!-- Inner Dashed orbit ring for the second track -->
          <div class="absolute lg:inset-[220px] border border-dashed border-slate-300/60 rounded-full"></div>
          <div class="absolute lg:inset-[240px] border border-slate-100/60 rounded-full"></div>

          <!-- Central Hub: Glassmorphic Core -->
          <div class="absolute inset-0 m-auto lg:w-[260px] lg:h-[260px] rounded-full bg-white/95 backdrop-blur-xl shadow-[0_15px_40px_-5px_rgba(0,0,0,0.06)] border border-white flex items-center justify-center animate-spin-custom-reverse z-10">
            <div class="absolute inset-2 border border-slate-100/80 rounded-full pointer-events-none"></div>
            <div class="text-center px-4">
              <p class="lg:text-sm font-bold text-slate-500 tracking-[0.25em] uppercase">Trusted By</p>
              <p class="lg:text-xs text-slate-400 mt-2 uppercase tracking-widest leading-relaxed">Healthcare<br/>Leaders</p>
            </div>
          </div>

          <!-- The Spinning Logos: Double Ring Watch Dial Layout -->
          {logos.map((logo, i) => {
            const isOuter = i % 2 === 0;
            const outerCount = Math.ceil(logos.length / 2);
            const innerCount = Math.floor(logos.length / 2);
            const positionIndex = Math.floor(i / 2);
            
            const angle = isOuter 
               ? (positionIndex * (360 / outerCount))
               : (positionIndex * (360 / innerCount) + (360 / innerCount / 2)); // Stagger nicely
               
            const radiusClass = isOuter ? "lg:left-[350px]" : "lg:left-[230px]";
            const sizeClass = isOuter ? "lg:w-[100px] lg:h-[100px]" : "lg:w-[85px] lg:h-[85px] p-2";

            return (
              <div class="absolute top-1/2 left-1/2 w-0 h-0" style={`transform: rotate(${angle}deg)`}>
                <div class={`absolute ${radiusClass} -translate-x-1/2 -translate-y-1/2`}>
                  <div class="animate-spin-custom-reverse">
                    <div style={`transform: rotate(-${angle}deg)`}>
                      <!-- Premium Logo Bubbles -->
                      <div class={`bg-white rounded-full shadow-[0_4px_20px_rgba(0,0,0,0.04)] flex items-center justify-center border border-white/80 group hover:scale-[1.15] hover:shadow-2xl hover:shadow-slate-200/60 hover:border-white transition-all duration-300 cursor-pointer p-4 lg:p-5 relative backdrop-blur-md ${sizeClass}`}>
                        <img 
                          src={logo.src} 
                          alt={logo.alt} 
                          class="w-full h-full object-contain filter grayscale group-hover:grayscale-0 opacity-60 group-hover:opacity-100 transition-all duration-500 will-change-transform" 
                        />
                      </div>
                    </div>
                  </div>
                </div>
              </div>
            );
          })}

        </div>
      </div>

      <!-- Mobile Marquee Line -->
      <div 
        class="flex lg:hidden w-full flex-col items-center mt-12 pt-10 border-t border-slate-200/60 pb-8 z-20 relative"
      >
        <p class="text-[0.6rem] sm:text-xs font-bold text-slate-400 tracking-[0.2em] uppercase mb-8" data-reveal>
          Trusted By Leading Medical Brands
        </p>
        
        <div class="relative w-[100vw] sm:w-full overflow-hidden flex fade-edges -mx-4 sm:mx-0" data-reveal>
           <div class="animate-marquee flex items-center gap-10 sm:gap-14 w-max px-4">
            {[...logos, ...logos].map((logo) => (
              <img 
                src={logo.src} 
                alt={logo.alt} 
                class="w-16 h-16 sm:w-20 sm:h-20 object-contain filter grayscale opacity-60 hover:grayscale-0 hover:opacity-100 transition-all duration-300" 
              />
            ))}
          </div>
        </div>
      </div>

    </div>
  </div>
</div>

<style is:global>
  /* Mobile Marquee Logic */
  @keyframes marquee {
    0% { transform: translateX(0%); }
    100% { transform: translateX(-50%); }
  }
  .animate-marquee {
    animation: marquee 50s linear infinite;
  }
  .fade-edges {
    mask-image: linear-gradient(to right, transparent, black 15%, black 85%, transparent);
    -webkit-mask-image: linear-gradient(to right, transparent, black 15%, black 85%, transparent);
  }

  /* Custom Keyframes for the Spinning Wheel */
  @keyframes spin-custom {
    from { transform: rotate(0deg); }
    to { transform: rotate(360deg); }
  }
  @keyframes spin-custom-reverse {
    from { transform: rotate(360deg); }
    to { transform: rotate(0deg); }
  }
  .animate-spin-custom {
    animation: spin-custom 50s linear infinite;
  }
  .animate-spin-custom-reverse {
    animation: spin-custom-reverse 50s linear infinite;
  }
</style>

<script>
  import { gsap } from "gsap";
  import scrollToElement from "src/utils/scrollToElement.ts";

  // GSAP Animations
  const tl = gsap.timeline();

  // Animate the text and button on the left
  tl.fromTo(
    "[data-reveal]",
    { opacity: 0, y: 30 },
    { opacity: 1, y: 0, duration: 1, stagger: 0.15, ease: "power3.out" }
  );

  // Animate the intricate wheel rolling in
  tl.fromTo(
    "[data-reveal-container]",
    { opacity: 0, x: 80, rotation: 10 },
    { opacity: 1, x: 0, rotation: 0, duration: 1.5, ease: "power3.out", clearProps: "all" },
    "-=0.6"
  );

  // Handle CTA Click
  const hlmb = document.getElementById("hero_learn_more_btn");
  if (hlmb) {
    hlmb.addEventListener("click", () => {
      scrollToElement("service");
    });
  }
</script>
