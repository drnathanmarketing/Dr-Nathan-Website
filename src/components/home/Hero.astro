---
import glucos from "../../clients/1.png";
import dugro from "../../clients/2.png";
import avolac from "../../clients/3.png";
import sun from "../../clients/4.png";
import vital from "../../clients/5.png";
import roche from "../../clients/6.png";
import skinland from "../../clients/7.png";
import goneyay from "../../clients/8.png";
import ohoo from "../../clients/9.png";
import rejuve from "../../clients/10.png";
import homedoctor from "../../clients/11.png";
import s from "../../clients/12.png";

const clients = [
  glucos, dugro, avolac, sun, vital, roche,
  skinland, goneyay, ohoo, rejuve, homedoctor, s,
];
---

<div id="hero" class="relative min-h-[95vh] w-full flex flex-col items-center justify-center overflow-hidden bg-white px-4 pt-24 pb-16">

  <!-- Background Layer 1: Subtle Grid Texture -->
  <div class="absolute inset-0 bg-[linear-gradient(to_right,#80808012_1px,transparent_1px),linear-gradient(to_bottom,#80808012_1px,transparent_1px)] bg-[size:32px_32px] [mask-image:radial-gradient(ellipse_60%_60%_at_50%_50%,#000_10%,transparent_100%)] pointer-events-none"></div>

  <!-- Background Layer 2: Ambient glow blobs -->
  <div class="absolute top-[10%] right-[10%] w-[40vw] h-[40vw] sm:w-[400px] sm:h-[400px] rounded-full bg-primary-900/5 blur-[120px] pointer-events-none translate-x-1/3 -translate-y-1/3"></div>
  <div class="absolute bottom-[20%] left-[10%] w-[40vw] h-[40vw] sm:w-[400px] sm:h-[400px] rounded-full bg-gray-300/40 blur-[120px] pointer-events-none -translate-x-1/3 translate-y-1/3"></div>

  <!-- Background Layer 3: Elegant Concentric Rings -->
  <div class="absolute inset-0 flex items-center justify-center pointer-events-none opacity-30">
    <div class="absolute w-[100vw] h-[100vw] sm:w-[800px] sm:h-[800px] rounded-full border border-gray-200"></div>
    <div class="absolute w-[120vw] h-[120vw] sm:w-[1200px] sm:h-[1200px] rounded-full border border-primary-900/10"></div>
  </div>


  <!-- Main content (Foreground) -->
  <div class="relative z-10 max-w-screen-lg mx-auto flex flex-col items-center text-center mt-8">

    <!-- Live badge -->
    <div class="hero-anim opacity-0 mb-8 inline-flex items-center gap-2.5 px-4 py-2 rounded-full bg-white border border-gray-100 shadow-sm transition-transform hover:scale-105 cursor-default">
      <span class="relative flex h-2 w-2">
        <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-primary-900 opacity-75"></span>
        <span class="relative inline-flex rounded-full h-2 w-2 bg-primary-900"></span>
      </span>
      <span class="text-xs font-semibold uppercase tracking-widest text-gray-600">Dr. Nathan Marketing & Consultancy</span>
    </div>

    <!-- Heading -->
    <h1 class="hero-anim opacity-0 text-5xl sm:text-6xl md:text-7xl font-extrabold text-gray-900 tracking-tight leading-[1.1] mb-6">
      Elevate Your <br class="hidden sm:block" />
      <span class="text-transparent bg-clip-text bg-gradient-to-r from-gray-900 to-gray-500">Brand.</span>
    </h1>

    <!-- Subtitle -->
    <p class="hero-anim opacity-0 text-base sm:text-lg md:text-xl text-gray-500 max-w-2xl mx-auto leading-relaxed mb-10">
      We are dedicated, forward-thinking professionals committed to delivering innovative, premium marketing solutions tailored specifically for your healthcare practice.
    </p>

    <!-- CTAs -->
    <div class="hero-anim opacity-0 flex flex-col sm:flex-row items-center justify-center gap-4 w-full sm:w-auto">
      <button
        id="hero_learn_more_btn"
        class="group relative w-full sm:w-auto px-8 py-4 rounded-full bg-primary-900 text-white text-sm font-medium hover:bg-gray-900 transition-all duration-300 shadow-[0_8px_20px_-4px_rgba(0,74,125,0.4)] hover:shadow-[0_8px_20px_-4px_rgba(0,0,0,0.5)] hover:-translate-y-0.5 overflow-hidden"
      >
        <div class="absolute inset-0 h-full w-full translate-x-[-100%] bg-white/20 transition-transform duration-500 group-hover:translate-x-[100%]"></div>
        <span class="relative">Explore Our Services</span>
      </button>
      <button
        id="hero_book_btn"
        class="w-full sm:w-auto px-8 py-4 rounded-full bg-white/50 backdrop-blur-sm text-gray-900 text-sm font-medium border border-gray-200 hover:border-gray-400 hover:bg-white transition-all duration-300 text-center"
      >
        Book a Consultation
      </button>
    </div>
  </div>

  <!-- Infinite Marquee Logo Rail -->
  <div class="hero-anim opacity-0 relative z-10 w-full mt-20 sm:mt-28 pt-10 border-t border-gray-100">
    <p class="text-[10px] font-bold text-center text-gray-400 uppercase tracking-[0.2em] mb-8">
      Trusted by Leading Medical Brands
    </p>

    <!-- Fade mask on edges -->
    <div class="relative overflow-hidden w-full marquee-mask">
      <!-- Duplicated list for seamless loop -->
      <div class="marquee-track flex gap-10 sm:gap-14 items-center">
        {[...clients, ...clients].map((client) => (
          <img
            src={client.src}
            alt="Client Logo"
            class="h-8 sm:h-10 w-auto object-contain grayscale opacity-60 hover:grayscale-0 hover:opacity-100 transition-all duration-500 shrink-0"
          />
        ))}
      </div>
    </div>
  </div>
</div>

<!-- Use global style to guarantee animation is injected regardless of Tailwind JIT -->
<style is:global>
  @keyframes marquee {
    0%   { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }

  .marquee-track {
    display: flex;
    width: max-content;
    animation: marquee 28s linear infinite;
  }

  .marquee-mask {
    -webkit-mask-image: linear-gradient(to right, transparent, black 15%, black 85%, transparent);
    mask-image: linear-gradient(to right, transparent, black 15%, black 85%, transparent);
  }

  .marquee-track:hover {
    animation-play-state: paused;
  }
</style>

<script>
  import { gsap } from "gsap";
  import scrollToElement from "@utils/scrollToElement.ts";

  // Entry animation
  gsap.fromTo(
    ".hero-anim",
    { y: 30, opacity: 0 },
    { y: 0, opacity: 1, duration: 1.2, stagger: 0.15, ease: "power3.out", delay: 0.1 }
  );


  // CTA Button scrolling interaction
  const hlmb = document.getElementById("hero_learn_more_btn");
  if (hlmb) {
    hlmb.addEventListener("click", () => {
      scrollToElement("service");
    });
  }

  const hbb = document.getElementById("hero_book_btn");
  if (hbb) {
    hbb.addEventListener("click", () => {
      scrollToElement("contact_us");
    });
  }
</script>
