---
import glucos from "../../clients/1.png";
import dugro from "../../clients/2.png";
import avolac from "../../clients/3.png";
import sun from "../../clients/4.png";
import vital from "../../clients/5.png";
import roche from "../../clients/6.png";
import skinland from "../../clients/7.png";
import goneyay from "../../clients/8.png";
import ohoo from "../../clients/9.png";
import rejuve from "../../clients/10.png";
import homedoctor from "../../clients/11.png";
import s from "../../clients/12.png";

const logos = [
  { src: glucos.src, alt: "glucos" },
  { src: dugro.src, alt: "dugro" },
  { src: avolac.src, alt: "avolac" },
  { src: sun.src, alt: "sun" },
  { src: vital.src, alt: "vital" },
  { src: roche.src, alt: "roche" },
  { src: skinland.src, alt: "skinland" },
  { src: goneyay.src, alt: "goneyay" },
  { src: ohoo.src, alt: "ohoo" },
  { src: rejuve.src, alt: "rejuve" },
  { src: homedoctor.src, alt: "homedoctor" },
  { src: s.src, alt: "s" },
];
---

<div
  id="hero"
  class="relative min-h-[90vh] flex flex-col justify-center overflow-hidden bg-[#fafafa] sm:mb-8 md:mb-16 pt-24 lg:pt-0"
>
  <!-- Minimal Ambient Glow Background -->
  <div class="absolute inset-0 overflow-hidden pointer-events-none z-0">
    <div class="absolute top-[0%] left-[-10%] w-[60%] h-[60%] rounded-full bg-primary-50/40 blur-[120px]"></div>
  </div>

  <div class="max-w-screen-xl mx-auto px-4 py-8 md:py-20 relative z-10 w-full h-full">
    <div class="flex flex-col lg:flex-row items-center gap-12 lg:gap-8 relative w-full h-full">
      
      <!-- Left Column: Editorial Text -->
      <div class="flex-1 flex flex-col gap-6 lg:gap-8 items-center text-center lg:items-start lg:text-left z-20 w-full">
        <p 
          class="text-xs md:text-sm font-bold tracking-[0.25em] text-primary-600 uppercase"
          data-reveal
        >
          Dr. Nathan Marketing & Consultancy
        </p>
        
        <h1 
          class="text-5xl md:text-7xl lg:text-[5.5rem] font-bold tracking-tight text-slate-900 leading-[1.1] md:leading-[1.05]"
          data-reveal
        >
          Elevate Your <br class="hidden lg:block"/>
          <span class="text-transparent bg-clip-text bg-gradient-to-r from-primary-600 to-primary-400">Brand</span>
        </h1>
        
        <p 
          class="text-base md:text-lg text-slate-600 max-w-[500px] leading-relaxed"
          data-reveal
        >
          We are dedicated, forward-thinking professionals committed to exploring and delivering premium, innovative marketing solutions tailored for the healthcare industry.
        </p>
        
        <div class="pt-4" data-reveal>
          <button
            id="hero_learn_more_btn"
            type="button"
            class="group relative inline-flex items-center justify-center px-8 py-4 font-medium text-white transition-all duration-300 ease-out bg-slate-900 rounded-full hover:bg-slate-800 hover:shadow-xl hover:shadow-slate-900/20 hover:-translate-y-1 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-slate-900 w-max"
          >
            <span class="mr-2 tracking-wide text-sm md:text-base">Discover Our Expertise</span>
            <svg 
              class="w-5 h-5 transition-transform duration-300 ease-out group-hover:translate-x-1" 
              fill="none" viewBox="0 0 24 24" stroke="currentColor"
            >
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3" />
            </svg>
          </button>
        </div>
      </div>

      <!-- Right Column: Intricate Luxury Watch Dial Wheel -->
      <div 
        class="flex-1 w-full relative flex flex-col justify-center items-end h-[350px] sm:h-[450px] md:h-[600px] lg:h-[700px] pointer-events-none mt-4 lg:mt-0 z-10"
        data-reveal-container
      >
        <!-- The Wheel Container -> Adjusted upward per user feedback -->
        <div class="pointer-events-auto absolute top-4 sm:top-8 md:top-12 lg:top-12 right-[-100px] sm:right-[-150px] md:right-[-200px] lg:right-[-250px] w-[350px] h-[350px] sm:w-[500px] sm:h-[500px] md:w-[700px] md:h-[700px] lg:w-[900px] lg:h-[900px] rounded-full animate-spin-custom">
          
          <!-- Backing glass plate -->
          <div class="absolute inset-0 bg-gradient-to-br from-white/70 to-white/20 backdrop-blur-3xl rounded-full border border-white/60 shadow-[0_0_80px_rgba(0,0,0,0.03)]"></div>
          
          <!-- Outer fine rings -->
          <div class="absolute inset-[15px] sm:inset-[20px] md:inset-[30px] lg:inset-[40px] border border-slate-200/40 rounded-full"></div>
          <div class="absolute inset-[18px] sm:inset-[24px] md:inset-[34px] lg:inset-[44px] border border-slate-100/30 rounded-full"></div>
          
          <!-- Main dashed orbit ring -->
          <div class="absolute inset-[45px] sm:inset-[60px] md:inset-[80px] lg:inset-[100px] border border-dashed border-slate-300/80 rounded-full bg-slate-50/10"></div>
          <div class="absolute inset-[48px] sm:inset-[64px] md:inset-[84px] lg:inset-[104px] border border-slate-200/30 rounded-full"></div> 
          
          <!-- Inner rings -->
          <div class="absolute inset-[75px] sm:inset-[100px] md:inset-[140px] lg:inset-[180px] border border-slate-200/50 rounded-full bg-white/20"></div>
          <div class="absolute inset-[100px] sm:inset-[130px] md:inset-[180px] lg:inset-[240px] border border-slate-100/60 rounded-full"></div>

          <!-- Central Hub: Glassmorphic Core -->
          <div class="absolute inset-0 m-auto w-[100px] h-[100px] sm:w-[140px] sm:h-[140px] md:w-[200px] md:h-[200px] lg:w-[260px] lg:h-[260px] rounded-full bg-white/95 backdrop-blur-xl shadow-[0_15px_40px_-5px_rgba(0,0,0,0.06)] border border-white flex items-center justify-center animate-spin-custom-reverse z-10">
            <div class="absolute inset-2 border border-slate-100/80 rounded-full pointer-events-none"></div>
            <div class="text-center px-2 sm:px-4">
              <p class="text-[0.45rem] sm:text-[0.55rem] md:text-xs lg:text-sm font-bold text-slate-500 tracking-[0.25em] uppercase">Trusted By</p>
              <p class="text-[0.35rem] sm:text-[0.45rem] md:text-[0.6rem] lg:text-xs text-slate-400 mt-1 lg:mt-2 uppercase tracking-widest leading-relaxed">Healthcare<br/>Leaders</p>
            </div>
          </div>

          <!-- The Spinning Logos -->
          {logos.map((logo, i) => {
            const angle = i * 30; // 12 logos -> 30 degrees spacing
            return (
              <div class="absolute top-1/2 left-1/2 w-0 h-0" style={`transform: rotate(${angle}deg)`}>
                {/* 
                  Radius logic mapping perfectly to dashed rings:
                  lg: w=900 (r=450), inset=100 -> logo left=350px
                  md: w=700 (r=350), inset=80 -> logo left=270px
                  sm: w=500 (r=250), inset=60 -> logo left=190px
                  xs: w=350 (r=175), inset=45 -> logo left=130px
                */}
                <div class="absolute left-[130px] sm:left-[190px] md:left-[270px] lg:left-[350px] -translate-x-1/2 -translate-y-1/2">
                  <div class="animate-spin-custom-reverse">
                    <div style={`transform: rotate(-${angle}deg)`}>
                      <!-- Premium Logo Bubbles -->
                      <div class="w-[3rem] h-[3rem] sm:w-[3.5rem] sm:h-[3.5rem] md:w-20 md:h-20 lg:w-[100px] lg:h-[100px] bg-white rounded-full shadow-[0_4px_20px_rgba(0,0,0,0.04)] flex items-center justify-center border border-white/80 group hover:scale-[1.15] hover:shadow-2xl hover:shadow-slate-200/60 hover:border-white transition-all duration-300 cursor-pointer p-2 sm:p-3 md:p-5 relative backdrop-blur-md">
                        <img 
                          src={logo.src} 
                          alt={logo.alt} 
                          class="w-full h-full object-contain filter grayscale group-hover:grayscale-0 opacity-60 group-hover:opacity-100 transition-all duration-500 will-change-transform" 
                        />
                      </div>
                    </div>
                  </div>
                </div>
              </div>
            );
          })}

        </div>
      </div>

    </div>
  </div>
</div>

<style is:global>
  /* Custom Keyframes for the Spinning Wheel */
  @keyframes spin-custom {
    from { transform: rotate(0deg); }
    to { transform: rotate(360deg); }
  }
  @keyframes spin-custom-reverse {
    from { transform: rotate(360deg); }
    to { transform: rotate(0deg); }
  }
  .animate-spin-custom {
    animation: spin-custom 50s linear infinite;
  }
  .animate-spin-custom-reverse {
    animation: spin-custom-reverse 50s linear infinite;
  }
</style>

<script>
  import { gsap } from "gsap";
  import scrollToElement from "src/utils/scrollToElement.ts";

  // GSAP Animations
  const tl = gsap.timeline();

  // Animate the text and button on the left
  tl.fromTo(
    "[data-reveal]",
    { opacity: 0, y: 30 },
    { opacity: 1, y: 0, duration: 1, stagger: 0.15, ease: "power3.out" }
  );

  // Animate the intricate wheel rolling in
  tl.fromTo(
    "[data-reveal-container]",
    { opacity: 0, x: 80, rotation: 10 },
    { opacity: 1, x: 0, rotation: 0, duration: 1.5, ease: "power3.out", clearProps: "all" },
    "-=0.6"
  );

  // Handle CTA Click
  const hlmb = document.getElementById("hero_learn_more_btn");
  if (hlmb) {
    hlmb.addEventListener("click", () => {
      scrollToElement("service");
    });
  }
</script>
