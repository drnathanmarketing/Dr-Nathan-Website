---
import glucos from "../../clients/1.png";
import dugro from "../../clients/2.png";
import avolac from "../../clients/3.png";
import sun from "../../clients/4.png";
import vital from "../../clients/5.png";
import roche from "../../clients/6.png";
import skinland from "../../clients/7.png";
import goneyay from "../../clients/8.png";
import ohoo from "../../clients/9.png";
import rejuve from "../../clients/10.png";
import homedoctor from "../../clients/11.png";
import s from "../../clients/12.png";

const logos = [
  { src: glucos.src, alt: "glucos" },
  { src: dugro.src, alt: "dugro" },
  { src: avolac.src, alt: "avolac" },
  { src: sun.src, alt: "sun" },
  { src: vital.src, alt: "vital" },
  { src: roche.src, alt: "roche" },
  { src: skinland.src, alt: "skinland" },
  { src: goneyay.src, alt: "goneyay" },
  { src: ohoo.src, alt: "ohoo" },
  { src: rejuve.src, alt: "rejuve" },
  { src: homedoctor.src, alt: "homedoctor" },
  { src: s.src, alt: "s" },
];
---

<section id="hero" class="relative w-full min-h-[90vh] flex flex-col justify-center items-center overflow-hidden bg-gradient-to-b from-primary-50/30 to-white pt-24 pb-16">
  <!-- Decorative Background blobs for subtle glassmorphism -->
  <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[600px] h-[600px] md:w-[800px] md:h-[500px] bg-primary-100/50 rounded-full blur-[100px] -z-10 pointer-events-none"></div>

  <div class="max-w-screen-xl mx-auto px-4 w-full flex flex-col items-center text-center z-10">
    <div class="hero-content flex flex-col items-center gap-6 mt-10 md:mt-16">
      <span class="hero-badge px-4 py-1.5 rounded-full bg-primary-50 text-primary-800 text-[11px] md:text-xs font-semibold tracking-widest uppercase shadow-sm border border-primary-200/50 opacity-0">
        Dr. Nathan Marketing & Consultancy
      </span>
      
      <h1 class="hero-title text-5xl sm:text-6xl lg:text-7xl font-lato tracking-tight text-slate-800 opacity-0 leading-tight">
        <span class="font-light block mb-1 sm:mb-2">Premium Marketing for</span>
        <span class="font-bold text-transparent bg-clip-text bg-gradient-to-r from-primary-950 via-primary-800 to-primary-600">
          Medical Brands
        </span>
      </h1>

      <p class="hero-subtitle text-base md:text-lg text-slate-600 max-w-2xl mt-2 md:mt-4 opacity-0 leading-relaxed font-openSan px-4">
        We are dedicated, forward-thinking professionals committed to delivering tailored, innovative growth solutions for the healthcare industry.
      </p>

      <div class="hero-actions flex flex-col sm:flex-row gap-4 mt-6 md:mt-8 opacity-0 w-full sm:w-auto px-6 sm:px-0">
        <button id="hero_learn_more_btn" class="group relative px-8 py-3.5 bg-primary-900 text-white rounded-full font-medium transition-all duration-300 hover:bg-primary-800 hover:shadow-xl hover:shadow-primary-900/20 overflow-hidden transform hover:-translate-y-0.5 focus:outline-none w-full sm:w-auto flex justify-center">
          <span class="relative z-10 flex items-center gap-2">
            Discover Our Approach
            <svg class="w-4 h-4 transition-transform duration-300 group-hover:translate-y-1" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3"></path></svg>
          </span>
        </button>
        <button id="hero_contact_btn" class="px-8 py-3.5 bg-white text-primary-900 border border-primary-200 rounded-full font-medium transition-all duration-300 hover:bg-primary-50 hover:border-primary-300 focus:outline-none w-full sm:w-auto">
          Contact Us
        </button>
      </div>
    </div>

    <!-- Trust Banner -->
    <div class="hero-trust w-full mt-20 md:mt-28 opacity-0">
      <p class="text-[10px] md:text-xs text-slate-400 font-semibold tracking-widest uppercase mb-6 md:mb-8">Trusted by Industry Leaders</p>
      <div class="flex flex-wrap justify-center items-center gap-x-8 gap-y-6 md:gap-x-12 opacity-80 px-4">
        {logos.map((logo) => (
          <img 
            src={logo.src} 
            alt={logo.alt} 
            class="h-8 sm:h-10 md:h-12 w-auto object-contain grayscale opacity-50 transition-all duration-500 hover:grayscale-0 hover:opacity-100 hover:scale-105"
          />
        ))}
      </div>
    </div>
  </div>
</section>

<script>
  import { gsap } from "gsap";
  import scrollToElement from "src/utils/scrollToElement.ts";

  // Prevent multiple executions in case of re-renders
  let initialized = false;

  function initAnimations() {
    if (initialized) return;
    initialized = true;

    const tl = gsap.timeline({ defaults: { ease: "power3.out" } });

    // Ensure elements are invisible before starting, useful if script is delayed slightly
    gsap.set([".hero-badge", ".hero-title", ".hero-subtitle", ".hero-actions", ".hero-trust"], { opacity: 0 });

    tl.fromTo(".hero-badge", 
      { y: 20, opacity: 0 }, 
      { y: 0, opacity: 1, duration: 0.8 }
    )
    .fromTo(".hero-title",
      { y: 30, opacity: 0 },
      { y: 0, opacity: 1, duration: 0.8 },
      "-=0.6"
    )
    .fromTo(".hero-subtitle",
      { y: 20, opacity: 0 },
      { y: 0, opacity: 1, duration: 0.8 },
      "-=0.6"
    )
    .fromTo(".hero-actions",
      { y: 20, opacity: 0 },
      { y: 0, opacity: 1, duration: 0.8 },
      "-=0.6"
    )
    .fromTo(".hero-trust",
      { y: 20, opacity: 0 },
      { y: 0, opacity: 1, duration: 0.8 },
      "-=0.4"
    );

    const learnMoreBtn = document.getElementById("hero_learn_more_btn");
    if (learnMoreBtn) {
      learnMoreBtn.addEventListener("click", () => {
        scrollToElement("service");
      });
    }

    const contactBtn = document.getElementById("hero_contact_btn");
    if (contactBtn) {
      contactBtn.addEventListener("click", () => {
        scrollToElement("contact_us");
      });
    }
  }

  document.addEventListener('DOMContentLoaded', initAnimations);
  document.addEventListener('astro:page-load', () => { initialized = false; initAnimations(); });

  if (document.readyState === "complete" || document.readyState === "interactive") {
    setTimeout(initAnimations, 10);
  }
</script>
