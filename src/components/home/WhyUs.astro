<!-- ─────────────────────────── STYLES ─────────────────────────────────── -->
<style>
  /* ── Desktop: expanding panel behaviour ── */
  @media (min-width: 1024px) {
    .why-panels {
      border-bottom: 1px solid #f1f5f9; /* slate-100 */
    }
    .why-panel {
      flex: 1;
      min-height: 500px;
      /* Smooth flex expansion */
      transition:
        flex        0.75s cubic-bezier(0.25, 0.46, 0.45, 0.94),
        background-color 0.5s ease;
    }
    /* Shrink siblings when one is hovered */
    .why-panels:has(.why-panel:hover) .why-panel {
      flex: 0.5;
    }
    /* Expand the hovered panel */
    .why-panels .why-panel:hover {
      flex: 3.2;
      background-color: #f8fbff; /* near-white with tiny blue tint */
    }
    /* Top accent bar sweeps to full width on hover */
    .why-panel:hover .panel-accent {
      width: 100%;
    }
    /* Description hidden by default, reveals on hover */
    .panel-desc {
      opacity: 0;
      transform: translateY(10px);
      transition: opacity 0.45s ease 0.25s, transform 0.45s ease 0.25s;
    }
    .why-panel:hover .panel-desc {
      opacity: 1;
      transform: translateY(0);
    }
    /* Category arrow also reveals with slight delay */
    .panel-arrow {
      opacity: 0;
      transform: translateX(-6px);
      transition: opacity 0.4s ease 0.35s, transform 0.4s ease 0.35s;
    }
    .why-panel:hover .panel-arrow {
      opacity: 1;
      transform: translateX(0);
    }
  }

  /* ── Mobile: always visible ── */
  @media (max-width: 1023px) {
    .why-panel {
      min-height: 220px;
    }
    .panel-desc {
      opacity: 1;
      transform: none;
    }
    .panel-arrow {
      opacity: 1;
      transform: none;
    }
    /* Accent bar always visible on mobile */
    .panel-accent {
      width: 3rem !important;
    }
    .panel-icon {
      background-color: #eef8ff;
      color: #0068b4;
    }
  }
</style>

<!-- ─────────────────────────── SCRIPT ─────────────────────────────────── -->
<script>
  import gsap from "gsap";
  import scrollToElement from "src/utils/scrollToElement";

  /* CTA */
  const btn = document.getElementById("testimonial_contact_us_btn");
  if (btn) btn.addEventListener("click", () => scrollToElement("contact_us"));

  /* ── Header reveal on scroll ── */
  const headerEl = document.querySelector(".why-header");
  const headerObs = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (!entry.isIntersecting) return;

        const tl = gsap.timeline({ defaults: { ease: "power3.out" } });
        tl
          .fromTo(".why-eyebrow",   { opacity: 0, y: 18 }, { opacity: 1, y: 0, duration: 0.6 })
          .fromTo(".why-h2",        { opacity: 0, y: 24 }, { opacity: 1, y: 0, duration: 0.9 }, "-=0.4")
          .fromTo(".why-old-desc",  { opacity: 0, y: 20 }, { opacity: 1, y: 0, duration: 0.8 }, "-=0.5")
          .fromTo(".why-desc",      { opacity: 0, y: 12 }, { opacity: 1, y: 0, duration: 0.7 }, "-=0.55")
          .to(".why-rule",          { width: "100%", duration: 1.1, ease: "power2.inOut" },      "-=0.5");

        headerObs.unobserve(entry.target);
      });
    },
    { threshold: 0.3 }
  );
  if (headerEl) headerObs.observe(headerEl);

  /* ── Panels stagger reveal on scroll ── */
  const panelsEl = document.querySelector(".why-panels");
  const panelObs = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (!entry.isIntersecting) return;

        gsap.fromTo(
          ".why-panel",
          { opacity: 0, y: 36 },
          { opacity: 1, y: 0, duration: 0.8, stagger: 0.13, ease: "power3.out" }
        );
        gsap.fromTo(
          ".why-cta-label, .why-cta-btn",
          { opacity: 0, y: 16 },
          { opacity: 1, y: 0, duration: 0.7, stagger: 0.1, ease: "power3.out", delay: 0.6 }
        );

        panelObs.unobserve(entry.target);
      });
    },
    { threshold: 0.1 }
  );
  if (panelsEl) panelObs.observe(panelsEl);
</script>
